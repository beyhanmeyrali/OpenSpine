# OpenSpine — local development environment.
# Copy to .env and adjust as needed. .env is gitignored.

# Application
OPENSPINE_ENV=local
OPENSPINE_LOG_LEVEL=INFO

# PostgreSQL
OPENSPINE_DB_HOST=localhost
OPENSPINE_DB_PORT=5432
OPENSPINE_DB_NAME=openspine
OPENSPINE_DB_USER=openspine
OPENSPINE_DB_PASSWORD=openspine_dev_only

# Redis Streams (event bus)
OPENSPINE_REDIS_URL=redis://localhost:6379/0

# Qdrant (semantic index)
OPENSPINE_QDRANT_URL=http://localhost:6333

# Embeddings — any OpenAI-compatible /v1/embeddings provider works.
# Ollama default port is 11434; llama-server default is 8080.
# Pull the model first: `ollama pull qwen3-embedding:0.6b`
# (Qwen3-Embedding-0.6B: 1024-d, ~640 MB Q4_K_M, MTEB-multilingual 64.33)
OPENSPINE_OLLAMA_URL=http://localhost:11434
OPENSPINE_EMBEDDING_MODEL=qwen3-embedding:0.6b
OPENSPINE_EMBEDDING_DIM=1024

# OpenTelemetry
OPENSPINE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OPENSPINE_OTEL_SERVICE_NAME=openspine-api

# Authentication / sessions
# Used to sign session cookies and short-lived tokens. Generate a strong
# random value for any non-local deployment. NEVER commit a real secret.
OPENSPINE_SECRET_KEY=change-me-in-real-deployments-this-is-dev-only
OPENSPINE_SESSION_IDLE_MINUTES=30
OPENSPINE_SESSION_ABSOLUTE_HOURS=12
